{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "types": ["*"],
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "noEmit": false
  },
  "exclude": ["test", "dist"]
}
