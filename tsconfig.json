{
  "compilerOptions": {
    "types": ["*"],
    "module": "nodenext",
    "target": "esnext",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true
  }
}
