{
  "name": "@kemdict/json-to-ts",
  "version": "0.1.0",
  "description": "Convert json object to typescript interfaces",
  "keywords": [
    "typescript",
    "ts",
    "convert",
    "json",
    "util",
    "lib",
    "types"
  ],
  "type": "module",
  "types": "build/src/index.d.ts",
  "main": "build/src/index.js",
  "scripts": {
    "build": "rm -rf ./dist && tsc -p tsconfig-build.json",
    "start": "node --watch src/index.ts",
    "test": "npm run build && node --test",
    "test-reload": "node --test --watch"
  },
  "author": "https://github.com/mariusalch",
  "repository": {
    "type": "git",
    "url": "https://github.com/kemdict/json-to-ts.git"
  },
  "bugs": {
    "url": "https://github.com/kemdict/json-to-ts/issues"
  },
  "license": "ISC",
  "dependencies": {
    "pluralize": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pluralize": "^0.0.27",
    "typescript": "^6.0.0"
  }
}
